# ─── Admin Authentication (REQUIRED) ──────────────────────────────────────────
# Set these before deploying. Use a strong random string for ADMIN_SESSION_TOKEN.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-strong-password"
ADMIN_SESSION_TOKEN="replace-with-a-random-64-char-hex-string"

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/mehmaan_manor"

# ─── Cloudinary (for image uploads) ───────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Razorpay (for payments) ───────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_... keys for testing, rzp_live_... for real payments
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# ─── Resend (for booking confirmation + contact form emails) ───────────────────
RESEND_API_KEY="your-resend-api-key"
FROM_EMAIL="bookings@mehmaanmanor.com"
OWNER_EMAIL="simran@mehmaanmanor.com"

# ─── Twilio (optional — for SMS/WhatsApp notifications) ───────────────────────
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_PHONE_NUMBER="your-twilio-number"
