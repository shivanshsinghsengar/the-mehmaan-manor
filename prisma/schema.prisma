generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Bookings ─────────────────────────────────────────────────────────────────

model Booking {
  id             String   @id @default(cuid())
  bookingNumber  String   @unique
  propertyId     String
  propertyName   String
  guestName      String
  guestEmail     String
  guestPhone     String
  checkIn        String   // ISO date string "YYYY-MM-DD"
  checkOut       String
  nights         Int
  guests         Int
  baseAmount     Float
  cleaningFee    Float
  taxes          Float
  totalAmount    Float
  status         String   @default("PENDING_PAYMENT") // PENDING_PAYMENT | CONFIRMED | CANCELLED
  paymentId      String?
  razorpayOrderId String?
  specialRequests String  @default("")
  createdAt      String   // ISO datetime string

  @@index([status])
  @@index([checkIn])
  @@index([guestEmail])
  @@index([propertyId])
}

// ── Properties ───────────────────────────────────────────────────────────────

model Property {
  id           String   @id
  name         String
  slug         String   @unique
  address      String
  coordinates  String   @default("")
  description  String
  vibe         String
  baseRate     Float
  weekendRate  Float
  cleaningFee  Float
  maxGuests    Int
  checkInTime  String   @default("14:00")
  checkOutTime String   @default("11:00")
  amenities    String[]
  policies     String
  isActive     Boolean  @default(true)
  heroPhotoId  String?

  photos Photo[]
}

// ── Photos ────────────────────────────────────────────────────────────────────

model Photo {
  id         String   @id @default(cuid())
  url        String
  alt        String
  propertyId String?
  section    String   @default("gallery")
  order      Int      @default(0)
  isFeatured Boolean  @default(false)
  tags       String[]
  uploadedAt String

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([section])
}

// ── Site Content ──────────────────────────────────────────────────────────────

model SiteContent {
  id                 String @id @default("singleton")
  heroHeadline       String @default("The Mehmaan Experience")
  heroSubtitle       String @default("Two homes in Gurugram. Endless ways to feel at home.")
  philosophyText     String
  taglinePrimary     String @default("Not just a stay — it's the Mehmaan experience.")
  taglineSecondary   String @default("Two homes. One promise. Endless memories.")
  taglineCloser      String @default("Come as a guest, leave as family.")
  instagramHandle    String @default("@themehmaanmanor")
  teamSimranPhone    String @default("8828352311")
  teamVipinPhone     String @default("8796568003")
  teamJyotiPhone     String @default("8796568002")
}

// ── Inquiries ─────────────────────────────────────────────────────────────────

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  property  String   @default("")
  dates     String   @default("")
  message   String
  status    String   @default("NEW") // NEW | READ | REPLIED
  createdAt String

  @@index([status])
  @@index([createdAt])
}
